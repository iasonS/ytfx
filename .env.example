# YouTube Cookies (from private/incognito session)
# See README.md for how to export these
YOUTUBE_COOKIES=__Secure-3PSID=value;GPS=1;__Secure-1PSIDTS=value;...

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Database path (default: /data/ytfx.db on Render, /tmp/ytfx.db locally)
DB_PATH=/data/ytfx.db

# Optional: Token for /stats endpoint (required to access statistics)
STATS_TOKEN=your-secret-token-here
